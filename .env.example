# AIggs 数据库迁移管道 - 环境配置示例

# ============================================================================
# 数据库连接
# ============================================================================

# PostgreSQL 数据库连接字符串
# 格式: postgresql://[user[:password]@][host][:port][/database]
DATABASE_URL=postgresql://postgres:password@localhost:5432/aiggs

# 数据库主机
DB_HOST=localhost

# 数据库端口
DB_PORT=5432

# 数据库名称
DB_NAME=aiggs

# 数据库用户
DB_USER=postgres

# 数据库密码
DB_PASSWORD=password

# 数据库 SSL 模式 (disable, allow, prefer, require)
DB_SSL_MODE=prefer

# ============================================================================
# 迁移配置
# ============================================================================

# 迁移文件目录
MIGRATIONS_DIR=./migrations

# 影子表 Schema 名称
SHADOW_SCHEMA=shadow_testing

# 影子表测试数据子集大小（行数）
SHADOW_TEST_DATA_SIZE=1000000

# 迁移执行超时时间（秒）
MIGRATION_TIMEOUT=300

# 是否启用自动备份
AUTO_BACKUP_ENABLED=true

# 备份文件保存目录
BACKUP_DIR=./backups

# 备份保留时间（天）
BACKUP_RETENTION_DAYS=30

# ============================================================================
# 审批流程
# ============================================================================

# AI 置信度阈值（低于此值需要人工审批）
AI_CONFIDENCE_THRESHOLD=80

# 高风险迁移是否需要多人审批
REQUIRE_MULTI_APPROVAL_FOR_HIGH_RISK=true

# 审批所需的最少人数（当需要多人审批时）
MIN_APPROVAL_COUNT=2

# ============================================================================
# 蓝绿部署
# ============================================================================

# 蓝绿部署超时时间（秒）
BLUE_GREEN_TIMEOUT=3600

# 蓝环境保留时间（小时）
BLUE_ENVIRONMENT_RETENTION_HOURS=24

# 错误率告警阈值（%）
ERROR_RATE_THRESHOLD=1.0

# ============================================================================
# 监控和告警
# ============================================================================

# 监控启用开关
MONITORING_ENABLED=true

# 告警通知方式 (email, slack, pagerduty, none)
ALERT_NOTIFICATION_TYPE=email

# Slack Webhook URL（如果使用 Slack 通知）
SLACK_WEBHOOK_URL=

# 告警邮箱地址
ALERT_EMAIL_ADDRESS=

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 日志输出格式 (json, text)
LOG_FORMAT=text

# 日志文件保存目录
LOG_DIR=./logs

# ============================================================================
# 执行环境
# ============================================================================

# 环境标识 (development, staging, production)
NODE_ENV=development

# 调试模式
DEBUG=false

# 日期格式
DATE_FORMAT=YYYY-MM-DD HH:mm:ss
